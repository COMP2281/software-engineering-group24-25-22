from _typeshed import Incomplete

__all__ = ['amqp']

class AMQPContext:
    cli_context: Incomplete
    connection: Incomplete
    channel: Incomplete
    def __init__(self, cli_context) -> None: ...
    @property
    def app(self): ...
    def respond(self, retval) -> None: ...
    def echo_error(self, exception) -> None: ...
    def echo_ok(self) -> None: ...
    def reconnect(self) -> None: ...

def amqp(ctx) -> None: ...
