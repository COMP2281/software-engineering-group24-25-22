from _typeshed import Incomplete
from celery.apps.multi import MultiParser, NamespacedOptionParser

__all__ = ['MultiTool']

class TermLogger:
    splash_text: str
    splash_context: Incomplete
    retcode: int
    stdout: Incomplete
    stderr: Incomplete
    nosplash: Incomplete
    quiet: Incomplete
    verbose: Incomplete
    no_color: Incomplete
    def setup_terminal(self, stdout, stderr, nosplash: bool = False, quiet: bool = False, verbose: bool = False, no_color: bool = False, **kwargs) -> None: ...
    def ok(self, m, newline: bool = True, file: Incomplete | None = None): ...
    def say(self, m, newline: bool = True, file: Incomplete | None = None) -> None: ...
    def carp(self, m, newline: bool = True, file: Incomplete | None = None): ...
    def error(self, msg: Incomplete | None = None): ...
    def info(self, msg, newline: bool = True) -> None: ...
    def note(self, msg, newline: bool = True) -> None: ...
    def usage(self) -> None: ...
    def splash(self) -> None: ...
    def colored(self): ...

class MultiTool(TermLogger):
    MultiParser = MultiParser
    OptionParser = NamespacedOptionParser
    reserved_options: Incomplete
    env: Incomplete
    cmd: Incomplete
    fh: Incomplete
    prog_name: str
    commands: Incomplete
    def __init__(self, env: Incomplete | None = None, cmd: Incomplete | None = None, fh: Incomplete | None = None, stdout: Incomplete | None = None, stderr: Incomplete | None = None, **kwargs) -> None: ...
    def execute_from_commandline(self, argv, cmd: Incomplete | None = None): ...
    def validate_arguments(self, argv): ...
    def call_command(self, command, argv): ...
    def start(self, cluster): ...
    def stop(self, cluster, sig, **kwargs): ...
    def stopwait(self, cluster, sig, **kwargs): ...
    stop_verify = stopwait
    def restart(self, cluster, sig, **kwargs): ...
    def names(self, cluster) -> None: ...
    def get(self, wanted, *argv): ...
    def show(self, cluster): ...
    def kill(self, cluster): ...
    def expand(self, template, *argv): ...
    def help(self, *argv) -> None: ...
    def cluster_from_argv(self, argv, cmd: Incomplete | None = None): ...
    def Cluster(self, nodes, cmd: Incomplete | None = None): ...
    def on_stopping_preamble(self, nodes) -> None: ...
    def on_send_signal(self, node, sig) -> None: ...
    def on_still_waiting_for(self, nodes) -> None: ...
    def on_still_waiting_progress(self, nodes) -> None: ...
    def on_still_waiting_end(self) -> None: ...
    def on_node_signal_dead(self, node) -> None: ...
    def on_node_start(self, node) -> None: ...
    def on_node_restart(self, node) -> None: ...
    def on_node_down(self, node) -> None: ...
    def on_node_shutdown_ok(self, node) -> None: ...
    def on_node_status(self, node, retval) -> None: ...
    def on_node_signal(self, node, sig) -> None: ...
    def on_child_spawn(self, node, argstr, env) -> None: ...
    def on_child_signalled(self, node, signum) -> None: ...
    def on_child_failure(self, node, retcode) -> None: ...
    def OK(self): ...
    def FAILED(self): ...
    def DOWN(self): ...
