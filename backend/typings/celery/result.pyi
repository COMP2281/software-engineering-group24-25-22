from .exceptions import TimeoutError
from _typeshed import Incomplete
from collections.abc import Generator

__all__ = ['ResultBase', 'AsyncResult', 'ResultSet', 'GroupResult', 'EagerResult', 'result_from_tuple']

class ResultBase:
    parent: Incomplete

class AsyncResult(ResultBase):
    app: Incomplete
    TimeoutError = TimeoutError
    id: Incomplete
    backend: Incomplete
    parent: Incomplete
    on_ready: Incomplete
    def __init__(self, id, backend: Incomplete | None = None, task_name: Incomplete | None = None, app: Incomplete | None = None, parent: Incomplete | None = None) -> None: ...
    @property
    def ignored(self): ...
    @ignored.setter
    def ignored(self, value) -> None: ...
    def then(self, callback, on_error: Incomplete | None = None, weak: bool = False): ...
    def as_tuple(self): ...
    def as_list(self): ...
    def forget(self) -> None: ...
    def revoke(self, connection: Incomplete | None = None, terminate: bool = False, signal: Incomplete | None = None, wait: bool = False, timeout: Incomplete | None = None) -> None: ...
    def revoke_by_stamped_headers(self, headers, connection: Incomplete | None = None, terminate: bool = False, signal: Incomplete | None = None, wait: bool = False, timeout: Incomplete | None = None) -> None: ...
    def get(self, timeout: Incomplete | None = None, propagate: bool = True, interval: float = 0.5, no_ack: bool = True, follow_parents: bool = True, callback: Incomplete | None = None, on_message: Incomplete | None = None, on_interval: Incomplete | None = None, disable_sync_subtasks: bool = True, EXCEPTION_STATES=..., PROPAGATE_STATES=...): ...
    wait = get
    def collect(self, intermediate: bool = False, **kwargs) -> Generator[Incomplete]: ...
    def get_leaf(self): ...
    def iterdeps(self, intermediate: bool = False) -> Generator[Incomplete]: ...
    def ready(self): ...
    def successful(self): ...
    def failed(self): ...
    def throw(self, *args, **kwargs) -> None: ...
    def maybe_throw(self, propagate: bool = True, callback: Incomplete | None = None): ...
    maybe_reraise = maybe_throw
    def build_graph(self, intermediate: bool = False, formatter: Incomplete | None = None): ...
    def __hash__(self): ...
    def __eq__(self, other): ...
    def __copy__(self): ...
    def __reduce__(self): ...
    def __reduce_args__(self): ...
    def __del__(self) -> None: ...
    def graph(self): ...
    @property
    def supports_native_join(self): ...
    @property
    def children(self): ...
    @property
    def result(self): ...
    info = result
    @property
    def traceback(self): ...
    @property
    def state(self): ...
    status = state
    @property
    def task_id(self): ...
    @task_id.setter
    def task_id(self, id) -> None: ...
    @property
    def name(self): ...
    @property
    def args(self): ...
    @property
    def kwargs(self): ...
    @property
    def worker(self): ...
    @property
    def date_done(self): ...
    @property
    def retries(self): ...
    @property
    def queue(self): ...

class ResultSet(ResultBase):
    results: Incomplete
    on_ready: Incomplete
    def __init__(self, results, app: Incomplete | None = None, ready_barrier: Incomplete | None = None, **kwargs) -> None: ...
    def add(self, result) -> None: ...
    def remove(self, result) -> None: ...
    def discard(self, result) -> None: ...
    def update(self, results) -> None: ...
    def clear(self) -> None: ...
    def successful(self): ...
    def failed(self): ...
    def maybe_throw(self, callback: Incomplete | None = None, propagate: bool = True) -> None: ...
    maybe_reraise = maybe_throw
    def waiting(self): ...
    def ready(self): ...
    def completed_count(self): ...
    def forget(self) -> None: ...
    def revoke(self, connection: Incomplete | None = None, terminate: bool = False, signal: Incomplete | None = None, wait: bool = False, timeout: Incomplete | None = None) -> None: ...
    def __iter__(self): ...
    def __getitem__(self, index): ...
    def get(self, timeout: Incomplete | None = None, propagate: bool = True, interval: float = 0.5, callback: Incomplete | None = None, no_ack: bool = True, on_message: Incomplete | None = None, disable_sync_subtasks: bool = True, on_interval: Incomplete | None = None): ...
    def join(self, timeout: Incomplete | None = None, propagate: bool = True, interval: float = 0.5, callback: Incomplete | None = None, no_ack: bool = True, on_message: Incomplete | None = None, disable_sync_subtasks: bool = True, on_interval: Incomplete | None = None): ...
    def then(self, callback, on_error: Incomplete | None = None, weak: bool = False): ...
    def iter_native(self, timeout: Incomplete | None = None, interval: float = 0.5, no_ack: bool = True, on_message: Incomplete | None = None, on_interval: Incomplete | None = None): ...
    def join_native(self, timeout: Incomplete | None = None, propagate: bool = True, interval: float = 0.5, callback: Incomplete | None = None, no_ack: bool = True, on_message: Incomplete | None = None, on_interval: Incomplete | None = None, disable_sync_subtasks: bool = True): ...
    def __len__(self) -> int: ...
    def __eq__(self, other): ...
    @property
    def supports_native_join(self): ...
    @property
    def app(self): ...
    @app.setter
    def app(self, app) -> None: ...
    @property
    def backend(self): ...

class GroupResult(ResultSet):
    id: Incomplete
    results: Incomplete
    parent: Incomplete
    def __init__(self, id: Incomplete | None = None, results: Incomplete | None = None, parent: Incomplete | None = None, **kwargs) -> None: ...
    def save(self, backend: Incomplete | None = None): ...
    def delete(self, backend: Incomplete | None = None) -> None: ...
    def __reduce__(self): ...
    def __reduce_args__(self): ...
    def __bool__(self) -> bool: ...
    __nonzero__ = __bool__
    def __eq__(self, other): ...
    def __hash__(self): ...
    def as_tuple(self): ...
    @property
    def children(self): ...
    @classmethod
    def restore(cls, id, backend: Incomplete | None = None, app: Incomplete | None = None): ...

class EagerResult(AsyncResult):
    id: Incomplete
    on_ready: Incomplete
    def __init__(self, id, ret_value, state, traceback: Incomplete | None = None, name: Incomplete | None = None) -> None: ...
    def then(self, callback, on_error: Incomplete | None = None, weak: bool = False): ...
    def __reduce__(self): ...
    def __reduce_args__(self): ...
    def __copy__(self): ...
    def ready(self): ...
    def get(self, timeout: Incomplete | None = None, propagate: bool = True, disable_sync_subtasks: bool = True, **kwargs): ...
    wait = get
    def forget(self) -> None: ...
    def revoke(self, *args, **kwargs) -> None: ...
    @property
    def result(self): ...
    @property
    def state(self): ...
    status = state
    @property
    def traceback(self): ...
    @property
    def supports_native_join(self): ...

def result_from_tuple(r, app: Incomplete | None = None): ...
