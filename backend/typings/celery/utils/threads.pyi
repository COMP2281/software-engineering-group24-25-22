    def __call__(self): ...
    def push(self, obj): ...
    def pop(self): ...
    def __len__(self) -> int: ...
    @property
    def stack(self): ...
    @property
    def top(self): ...

class LocalManager:
    locals: Incomplete
    ident_func: Incomplete
    def __init__(self, locals: Incomplete | None = None, ident_func: Incomplete | None = None) -> None: ...
    def get_ident(self): ...
    def cleanup(self) -> None: ...

class _FastLocalStack(threading.local):
    stack: Incomplete
